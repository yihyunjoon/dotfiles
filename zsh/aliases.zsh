# Directory shortcuts
alias ...='../..'
alias ....='../../..'

# Common tools
alias l='eza -al'
alias nv='nvim'
alias pn='pnpm'
alias npx='pnpm dlx'
alias r='cargo'
alias u='uv run'
alias th='trash'
alias ij='zellij'

# Git and GitHub
alias g='git'
alias gs='git switch'
alias gp='git push'
alias gc='gh repo clone'

# CLI helpers
alias sudo='sudo '
alias reload='exec $(SHELL) -l'
alias cld='claude --dangerously-skip-permissions'
alias pil='pi --no-skills --skill ./.agents/skills' # pi with local skills only (./.agents/skills)
